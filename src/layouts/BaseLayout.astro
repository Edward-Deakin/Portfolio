---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
const { title = "Edward Deakin" } = Astro.props;
---
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PC50XWN4WK"></script>
    <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', 'G-PC50XWN4WK');
    </script>
</head>
<body class="bg-background text-foreground min-h-screen">
<slot />
</body>
</html>